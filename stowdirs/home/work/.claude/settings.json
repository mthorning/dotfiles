  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cmd=\"${TOOL_INPUT_command:-}\"; if echo \"$cmd\" | grep -qE \"(^|[[:space:]])git([[:space:]]|$)\"; then echo \"Use jj instead of git.\"; exit 2; fi; if echo \"$cmd\" | grep -qE \"(^|&&|;|\\|\\|)[[:space:]]*cd[[:space:]/~]\"; then echo \"Do not use cd — use absolute paths or pnpm --filter instead (jj workspace constraint).\"; exit 2; fi; exit 0'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'workspace_dir=\"\"; current=\"$PWD\"; while [[ \"$current\" != \"/\" ]]; do if [[ \"$(basename \"$current\")\" == workspace-* ]]; then workspace_dir=\"$current\"; break; fi; current=\"$(dirname \"$current\")\"; done; [[ -z \"$workspace_dir\" ]] && exit 0; file_path=\"${TOOL_INPUT_file_path:-}\"; if [[ -n \"$file_path\" && \"$file_path\" != \"$workspace_dir\"* ]]; then echo \"Blocked: $file_path is outside workspace $workspace_dir\"; exit 2; fi; exit 0'"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Read|Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/nono-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/mthorning/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}