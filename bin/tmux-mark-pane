#!/usr/bin/env bash

PANE_ID=$(tmux display-message -p '#{pane_id}')

raw=$(tmux show-environment -g TMUX_MARKED_PANES 2>/dev/null || true)
if [[ "$raw" == TMUX_MARKED_PANES=* ]]; then
    MARKED="${raw#TMUX_MARKED_PANES=}"
else
    MARKED=""
fi

if [[ ":${MARKED}:" == *":${PANE_ID}:"* ]]; then
    NEW=""
    IFS=':' read -ra PANES <<< "$MARKED"
    for P in "${PANES[@]}"; do
        [[ "$P" == "$PANE_ID" ]] && continue
        NEW="${NEW:+$NEW:}$P"
    done
    MARKED="$NEW"
    tmux set-option -up -t "$PANE_ID" @marked
    tmux display-message -d 1000 "unmarked"
else
    MARKED="${MARKED:+$MARKED:}${PANE_ID}"
    tmux set-option -p -t "$PANE_ID" @marked 1
    tmux display-message -d 1000 "marked"
fi

tmux set-environment -g TMUX_MARKED_PANES "$MARKED"
tmux set-environment -g TMUX_MARKED_INDEX "-1"

MARK_COLOR="#a6cc70"
if defaults read -g AppleInterfaceStyle 2>/dev/null | grep -q Dark; then
    BORDER="#343d4a"
    ACTIVE="#ffcc66"
else
    BORDER="#e7eaed"
    ACTIVE="#fa8d3e"
fi

tmux set-option -g pane-border-style "fg=#{?@marked,$MARK_COLOR,$BORDER}"
tmux set-option -g pane-active-border-style "fg=#{?@marked,$MARK_COLOR,$ACTIVE}"
