{
  "$schema": "./extensions/pi-permission-system/schemas/permissions.schema.json",
  
  "defaultPolicy": {
    "tools": "allow",
    "bash": "ask",
    "mcp": "ask",
    "skills": "allow",
    "special": "ask"
  },

  "tools": {
    "read": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "write": "allow",
    "edit": "allow"
  },

  "bash": {
    // ── Common read-only / low-risk inspection → allow ──
    "cd *": "allow",
    "pwd": "allow",
    "pwd *": "allow",
    "which *": "allow",
    "command -v *": "allow",
    "type *": "allow",
    "env": "allow",
    "printenv *": "allow",
    "echo *": "allow",
    "printf *": "allow",
    "cat *": "allow",
    "head *": "allow",
    "tail *": "allow",
    "less *": "allow",
    "wc *": "allow",
    "sort *": "allow",
    "uniq *": "allow",
    "cut *": "allow",
    "tr *": "allow",
    "sed *": "allow",
    "awk *": "allow",
    "grep *": "allow",
    "rg *": "allow",
    "find *": "allow",
    "fd *": "allow",
    "ls *": "allow",
    "ls": "allow",
    "lsd *": "allow",
    "lsd": "allow",
    "tree *": "allow",
    "file *": "allow",
    "stat *": "allow",
    "realpath *": "allow",
    "dirname *": "allow",
    "basename *": "allow",
    "readlink *": "allow",
    "test *": "allow",
    "[ *": "allow",
    "diff *": "allow",
    "comm *": "allow",
    "tee *": "allow",
    "xargs *": "allow",
    "date *": "allow",
    "date": "allow",
    "uname *": "allow",
    "hostname": "allow",
    "id": "allow",
    "whoami": "allow",
    "du *": "allow",
    "df *": "allow",
    "bat *": "allow",
    "jq *": "allow",
    "python3 -c *": "allow",
    "node -e *": "allow",
    "git status*": "allow",
    "git diff*": "allow",
    "git log*": "allow",
    "git show*": "allow",
    "git branch*": "allow",
    "git remote*": "allow",
    "git rev-parse*": "allow",
    "git config --get *": "allow",
    "git ls-files*": "allow",
    "jj status*": "allow",
    "jj diff*": "allow",
    "jj log*": "allow",
    "jj show*": "allow",
    "jj bookmark list*": "allow",
    "jj describe *": "allow",
    "jj commit *": "allow",
    "jj bookmark set *": "allow",
    "jj new *": "allow",
    "jj new": "allow",
    "gh pr view *": "allow",
    "gh pr diff *": "allow",
    "gh pr list *": "allow",
    "gh repo view *": "allow",
    "gh issue view *": "allow",
    "gh issue list *": "allow",
    "tmux list-panes*": "allow",
    "tmux capture-pane*": "ask",
    "bash ~/dotfiles/skills/pr-workflow/scripts/get_pr_reviews.sh *": "allow",
    "bash ~/dotfiles/skills/pr-workflow/scripts/update-pr.sh *": "ask",
    "bash ~/dotfiles/skills/jj/scripts/get-bookmark.sh *": "allow",
    "bash ~/dotfiles/skills/jj/scripts/commit-and-push.sh *": "ask",
    "bash ~/dotfiles/skills/notes/scripts/sync-notes.sh *": "allow",

    // ── Composite commands (pipes, chains) → ask ──
    // These override earlier "allow" rules for simple commands
    // when they appear in compound expressions.
    "*|*": "ask",
    "*&&*": "ask",
    "*;*": "ask",
    "*||*": "ask",

    // ── Destructive / irreversible → ask ──
    "rm *": "ask",
    "rmdir *": "ask",

    // ── Cross-pane / terminal control → ask ──
    "tmux send-keys *": "ask",
    "tmux respawn-pane *": "ask",
    "tmux run-shell *": "ask",
    "tmux pipe-pane *": "ask",
    
    "git push *": "ask",
    "git push": "ask",
    "git fetch *": "ask",
    "git fetch": "ask",
    "git pull *": "ask",
    "git pull": "ask",
    "git merge *": "ask",
    "git rebase *": "ask",
    "git cherry-pick *": "ask",
    
    "jj git push *": "ask",
    "jj git fetch *": "ask",
    "jj git fetch": "ask",
    
    "gh pr create *": "ask",
    "gh pr edit *": "ask",
    "gh pr merge *": "ask",
    "gh pr close *": "ask",
    "gh issue create *": "ask",
    "gh issue close *": "ask",
    "gh release create *": "ask",

    // ── Hard deny — dangerous or irreversible ──
    // Git destructive
    "git reset --hard *": "deny",
    "git clean *": "deny",
    "git branch -D *": "deny",
    "git filter-branch *": "deny",
    "git reflog delete *": "deny",
    
    // Jujutsu destructive
    "jj git push --force *": "deny",
    "jj abandon *": "deny",
    "jj bookmark delete *": "deny",
    "jj bookmark forget *": "deny",
    "jj operation abandon *": "deny",
    
    // GitHub destructive
    "gh api *--method DELETE*": "deny",
    "gh api *-X DELETE*": "deny",
    "gh repo delete *": "deny",
    "gh repo archive *": "deny",
    "gh secret set *": "deny",
    "gh secret delete *": "deny",
    
    // System admin
    "sudo *": "deny",
    "su *": "deny",
    "shutdown *": "deny",
    "reboot *": "deny",
    
    // Publishing
    "npm publish *": "deny",
    "npm unpublish *": "deny",
    "pnpm publish *": "deny",
    "pnpm unpublish *": "deny",
    
    // Production deploys
    "*deploy*production *": "deny",
    "*prod*deploy *": "deny",
    
    // Secrets
    "cat .env *": "deny",
    "cat **/secrets/**": "deny",
    "git add .env *": "deny",
    "git add **/secrets/**": "deny",
    
    // Dangerous shell patterns
    "eval *": "deny",
    "exec *": "deny",
    "source /dev *": "deny",
    ". /dev *": "deny"
  },

  "special": {
    "doom_loop": "deny",
    "external_directory": "ask"
  }
}
