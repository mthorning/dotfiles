{
  "$schema": "./extensions/pi-permission-system/schemas/permissions.schema.json",
  
  "defaultPolicy": {
    "tools": "allow",
    "bash": "allow",
    "mcp": "ask",
    "skills": "allow",
    "special": "ask"
  },

  "tools": {
    "read": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "write": "allow",
    "edit": "allow"
  },

  "bash": {
    // ── Destructive / irreversible → ask ──
    "rm *": "ask",
    "rmdir *": "ask",
    
    "git push *": "ask",
    "git push": "ask",
    "git fetch *": "ask",
    "git fetch": "ask",
    "git pull *": "ask",
    "git pull": "ask",
    "git merge *": "ask",
    "git rebase *": "ask",
    "git cherry-pick *": "ask",
    
    "jj git push *": "ask",
    "jj git fetch *": "ask",
    "jj git fetch": "ask",
    
    "gh pr create *": "ask",
    "gh pr merge *": "ask",
    "gh pr close *": "ask",
    "gh issue create *": "ask",
    "gh issue close *": "ask",
    "gh release create *": "ask",

    // ── Hard deny — dangerous or irreversible ──
    // Git destructive
    "git reset --hard *": "deny",
    "git clean *": "deny",
    "git branch -D *": "deny",
    "git filter-branch *": "deny",
    "git reflog delete *": "deny",
    
    // Jujutsu destructive
    "jj git push --force *": "deny",
    "jj abandon *": "deny",
    "jj bookmark delete *": "deny",
    "jj bookmark forget *": "deny",
    "jj operation abandon *": "deny",
    
    // GitHub destructive
    "gh api *--method DELETE*": "deny",
    "gh api *-X DELETE*": "deny",
    "gh repo delete *": "deny",
    "gh repo archive *": "deny",
    "gh secret set *": "deny",
    "gh secret delete *": "deny",
    
    // System admin
    "sudo *": "deny",
    "su *": "deny",
    "shutdown *": "deny",
    "reboot *": "deny",
    
    // Publishing
    "npm publish *": "deny",
    "npm unpublish *": "deny",
    "pnpm publish *": "deny",
    "pnpm unpublish *": "deny",
    
    // Production deploys
    "*deploy*production *": "deny",
    "*prod*deploy *": "deny",
    
    // Secrets
    "cat .env *": "deny",
    "cat **/secrets/**": "deny",
    "git add .env *": "deny",
    "git add **/secrets/**": "deny",
    
    // Dangerous shell patterns
    "eval *": "deny",
    "exec *": "deny",
    "source /dev *": "deny",
    ". /dev *": "deny"
  },

  "special": {
    "doom_loop": "deny",
    "external_directory": "ask"
  }
}
