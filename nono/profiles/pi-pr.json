{
  "$schema": "https://nono.dev/schemas/nono-profile.schema.json",
  "meta": {
    "name": "pi-pr",
    "version": "1.0.0",
    "description": "Elevated pi profile for PR creation/update and approved remote VCS sync"
  },
  "extends": "default",
  "workdir": {
    "access": "readwrite"
  },
  "security": {
    "groups": [
      "claude_code_macos",
      "user_caches_macos",
      "node_runtime",
      "rust_runtime",
      "python_runtime",
      "vscode_macos",
      "git_config",
      "unlink_protection"
    ]
  },
  "filesystem": {
    "allow": [
      "$HOME/.nvm/versions/node",
      "$HOME/.pi",
      "$HOME/.agents",
      "$HOME/.config",
      "$HOME/.npm",
      "$HOME/.local/share",
      "$HOME/.cache/pre-commit",
      "$HOME/.dart-tool",
      "$HOME/.pub-cache",
      "$HOME/dotfiles",
      "$HOME/development/flutter",
      "/Users/mthorning/Documents/Notes"
    ],
    "read": [
      "$HOME/grafana",
      "$HOME/.ssh/config",
      "$HOME/.ssh/known_hosts",
      "$HOME/.orbstack/ssh/config",
      "$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
    ]
  },
  "policy": {
    "override_deny": [
      "$HOME/.ssh/config",
      "$HOME/.ssh/known_hosts",
      "$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
    ]
  },
  "rollback": {
    "exclude_patterns": ["node_modules", ".next", "__pycache__", "target"],
    "exclude_globs": ["*.tmp.[0-9]*.[0-9]*"]
  },
  "network": {
    "block": false
  }
}
