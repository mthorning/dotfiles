{
  "$schema": "https://nono.dev/schemas/nono-profile.schema.json",
  "meta": {
    "name": "pi",
    "version": "1.0.0",
    "description": "pi-coding-agent sandbox — mirrors claude-code built-in profile"
  },
  "extends": "default",
  "workdir": {
    "access": "readwrite"
  },
  "security": {
    "groups": [
      "claude_code_macos",
      "user_caches_macos",
      "node_runtime",
      "rust_runtime",
      "python_runtime",
      "vscode_macos",
      "git_config",
      "unlink_protection"
    ]
  },
  "filesystem": {
    "allow": [
      "$HOME/.nvm/versions/node",
      "$HOME/.pi",
      "$HOME/.agents",
      "$HOME/.config",
      "$HOME/.npm",
      "$HOME/.local/share",
      "$HOME/.ssh",
      "$HOME/.cache/pre-commit",
      "$HOME/.dart-tool",
      "$HOME/.pub-cache",
      "$HOME/grafana",
      "$HOME/dotfiles",
      "$HOME/development/flutter"
    ]
  },
  "rollback": {
    "exclude_patterns": ["node_modules", ".next", "__pycache__", "target"],
    "exclude_globs": ["*.tmp.[0-9]*.[0-9]*"]
  },
  "network": {
    "block": false
  }
}
