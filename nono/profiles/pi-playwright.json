{
  "$schema": "https://nono.dev/schemas/nono-profile.schema.json",
  "meta": {
    "name": "pi-playwright",
    "version": "1.0.0",
    "description": "Dedicated pi profile for local-only Playwright automation using system Chrome"
  },
  "extends": "default",
  "workdir": {
    "access": "readwrite"
  },
  "security": {
    "groups": [
      "claude_code_macos",
      "user_caches_macos",
      "node_runtime",
      "rust_runtime",
      "python_runtime",
      "vscode_macos",
      "git_config",
      "unlink_protection"
    ]
  },
  "filesystem": {
    "allow": [
      "$HOME/.nvm/versions/node",
      "$HOME/.pi",
      "$HOME/.agents",
      "$HOME/.config",
      "$HOME/.npm",
      "$HOME/.local/share",
      "$HOME/.cache/pre-commit",
      "$HOME/.dart-tool",
      "$HOME/.pub-cache",
      "$HOME/dotfiles",
      "$HOME/development/flutter",
      "/Users/mthorning/Documents/Notes",
      "$HOME/Library/Application Support/Google/Chrome",
      "$HOME/Library/Caches/Google/Chrome"
    ],
    "read": [
      "$HOME/grafana",
      "/Applications/Google Chrome.app"
    ]
  },
  "rollback": {
    "exclude_patterns": ["node_modules", ".next", "__pycache__", "target"],
    "exclude_globs": ["*.tmp.[0-9]*.[0-9]*"]
  },
  "network": {
    "block": true,
    "open_port": [3000, 4173, 5173, 8000, 8080, 9222]
  }
}
