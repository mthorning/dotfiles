(version 1)

;; =============================================================================
;; Custom Agent Sandbox Profile — /Users/mthorning
;; Stack  : Node v24 (nvm·XDG) · pnpm · yarn · Go · Rust · Deno · Ruby · Java 17
;;          Python (homebrew + uv) · jj
;; Agents : claude-code · cursor-agent · codex
;; Section order mirrors Agent Safehouse: 00→10→20→30→40→50→55→60→paths
;; =============================================================================

;; ---------------------------------------------------------------------------
;; 00-base  ·  Macros, HOME definition, deny-first default
;; Source influence: 00-base.sb
;; ---------------------------------------------------------------------------

(define HOME_DIR "/Users/mthorning")

(define (home-subpath rel) (subpath (string-append HOME_DIR rel)))
(define (home-literal  rel) (literal (string-append HOME_DIR rel)))
(define (home-prefix   rel) (prefix  (string-append HOME_DIR rel)))

(deny default)

;; ---------------------------------------------------------------------------
;; 10-system-runtime  ·  Process execution, /tmp, /dev, system binaries
;; Source influence: 10-system-runtime.sb (verbatim)
;; ---------------------------------------------------------------------------

(allow file-read*
    (literal "/")                                              ;; Darwin 25+ requires root dir readability
    (subpath "/usr")
    (subpath "/bin")
    (subpath "/sbin")
    (subpath "/opt")                                          ;; homebrew lives here (/opt/homebrew)
    (subpath "/System/Library")
    (subpath "/System/Volumes/Preboot")
    (subpath "/Library/Apple")
    (subpath "/Library/Frameworks")
    (subpath "/Library/Fonts")
    (subpath "/Library/Filesystems/NetFSPlugins")
    (subpath "/Library/Preferences/Logging")
    (literal "/Library/Preferences/.GlobalPreferences.plist")
    (literal "/Library/Preferences/com.apple.networkd.plist")
    (literal "/dev"))

(allow file-read-metadata
    (subpath "/System")
    (subpath "/private/var/run"))

(allow file-read*
    (literal "/private")
    (literal "/private/var")
    (subpath "/private/var/db/timezone")
    (literal "/private/var/select/sh")
    (literal "/private/var/select/developer_dir")
    (literal "/var/select/developer_dir")
    (literal "/private/var/db/xcode_select_link")
    (literal "/var/db/xcode_select_link")
    (literal "/private/etc/hosts")
    (literal "/private/etc/resolv.conf")
    (literal "/private/etc/services")
    (literal "/private/etc/protocols")
    (literal "/private/etc/shells")
    (subpath "/private/etc/ssl")
    (literal "/private/etc/localtime")
    (literal "/etc")
    (literal "/var"))

(allow file-read-metadata
    (literal "/home")
    (literal "/private/etc")
    (subpath "/dev")
    (home-literal "/.config")
    (home-literal "/.cache")
    (home-literal "/.local")
    (home-literal "/.local/share"))

(allow file-read*
    (home-prefix "/Library/Preferences/.GlobalPreferences")
    (home-prefix "/Library/Preferences/com.apple.GlobalPreferences")
    (home-subpath "/Library/Preferences/ByHost")
    (home-literal "/.CFUserTextEncoding")
    (home-literal "/.config")
    (home-literal "/.cache"))

;; All ~/.local/bin binaries (read, no write — agents should not modify tool binaries)
(allow file-read*
    (home-subpath "/.local/bin"))

(allow process-exec)
(allow process-fork)
(allow sysctl-read)
(allow process-info* (target same-sandbox))
(allow signal (target same-sandbox))
(allow mach-priv-task-port (target same-sandbox))
(allow pseudo-tty)

(allow file-read* file-write*
    (subpath "/tmp")
    (subpath "/private/tmp")
    (subpath "/var/folders")
    (subpath "/private/var/folders"))

(deny file-read* file-write*
    (regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$")
    (regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$"))

(allow file-read* file-write*
    (subpath "/dev/fd")
    (literal "/dev/stdout")
    (literal "/dev/stderr")
    (literal "/dev/null")
    (literal "/dev/tty")
    (literal "/dev/ptmx")
    (literal "/dev/dtracehelper")
    (regex #"^/dev/tty")
    (regex #"^/dev/ttys")
    (regex #"^/dev/pty"))

(allow file-read*
    (literal "/dev/zero")
    (literal "/dev/autofs_nowait")
    (literal "/dev/dtracehelper")
    (literal "/dev/urandom")
    (literal "/dev/random"))

(allow file-ioctl
    (literal "/dev/dtracehelper")
    (literal "/dev/tty")
    (literal "/dev/ptmx")
    (regex #"^/dev/tty")
    (regex #"^/dev/ttys")
    (regex #"^/dev/pty"))

(allow mach-lookup
    (global-name "com.apple.system.notification_center")
    (global-name "com.apple.system.opendirectoryd.libinfo")
    (global-name "com.apple.logd")
    (global-name "com.apple.FSEvents")
    (global-name "com.apple.SystemConfiguration.configd")
    (global-name "com.apple.SystemConfiguration.DNSConfiguration")
    (global-name "com.apple.trustd.agent")
    (global-name "com.apple.diagnosticd")
    (global-name "com.apple.analyticsd")
    (global-name "com.apple.dnssd.service")
    (global-name "com.apple.CoreServices.coreservicesd")
    (global-name "com.apple.DiskArbitration.diskarbitrationd")
    (global-name "com.apple.analyticsd.messagetracer")
    (global-name "com.apple.system.logger")
    (global-name "com.apple.coreservices.launchservicesd")
    (global-name "com.apple.pasteboard.pbs"))

(allow system-socket)

(allow ipc-posix-shm-read-data
    (ipc-posix-name "apple.shm.notification_center"))

;; ---------------------------------------------------------------------------
;; 20-network  ·  Full network access (outbound + localhost dev servers)
;; Source influence: 20-network.sb
;; Note: blocking exfiltration/C2 is NOT a goal; reliable agent tooling is.
;; ---------------------------------------------------------------------------

(allow network*)

;; ---------------------------------------------------------------------------
;; 30-toolchains/node  ·  Node v24 via nvm stored at ~/.config/nvm (XDG path)
;; Source influence: 30-toolchains/node.sb
;; Deviation: nvm here is installed via homebrew; managed Nodes land in
;;   ~/.config/nvm/versions/ rather than the default ~/.nvm/versions/.
;; pnpm global store is at ~/Library/pnpm (macOS default).
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    ;; nvm — XDG install root (homebrew nvm uses ~/.config/nvm, not ~/.nvm)
    (home-subpath "/.config/nvm")

    ;; npm
    (home-subpath "/.npm")
    (home-subpath "/.config/npm")
    (home-subpath "/.cache/npm")
    (home-subpath "/.cache/node")
    (home-literal "/.npmrc")
    (home-subpath "/.config/configstore")        ;; npm ecosystem config persistence
    (home-subpath "/.node-gyp")
    (home-subpath "/.cache/node-gyp")

    ;; pnpm — macOS global store lives under ~/Library/pnpm
    (home-subpath "/.config/pnpm")
    (home-subpath "/.local/share/pnpm")
    (home-subpath "/.local/state/pnpm")
    (home-subpath "/Library/pnpm")
    (home-subpath "/Library/Caches/pnpm")
    (home-subpath "/Library/Preferences/pnpm")   ;; pnpm-managed global npmrc

    ;; yarn (homebrew classic)
    (home-subpath "/.yarn")
    (home-literal "/.yarnrc")
    (home-subpath "/.config/yarn")
    (home-subpath "/.cache/yarn")
    (home-subpath "/Library/Caches/Yarn")

    ;; corepack
    (home-subpath "/.cache/node/corepack")
    (home-subpath "/Library/Caches/node/corepack")

    ;; Turborepo build cache
    (home-subpath "/.cache/turbo")
    (home-subpath "/Library/Caches/turbo"))

(allow file-read-metadata
    (home-literal "/Library")
    (home-literal "/Library/Application Support"))

;; ---------------------------------------------------------------------------
;; 30-toolchains/go  ·  Go via /opt/homebrew/bin/go
;; Source influence: 30-toolchains/go.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/go")
    (home-subpath "/.cache/go-build")
    (home-subpath "/Library/Caches/go-build")
    (home-subpath "/.config/go")
    (home-subpath "/.local/share/go"))

;; ---------------------------------------------------------------------------
;; 30-toolchains/rust  ·  Rust via ~/.cargo + ~/.rustup
;; Source influence: 30-toolchains/rust.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.cargo")
    (home-subpath "/.config/cargo")
    (home-subpath "/.rustup")
    (home-subpath "/.cache/cargo")
    (home-subpath "/Library/Caches/cargo"))

;; ---------------------------------------------------------------------------
;; 30-toolchains/deno  ·  Deno at ~/.deno/
;; Source influence: 30-toolchains/deno.sb (structure follows safehouse pattern)
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.deno")
    (home-subpath "/.cache/deno")
    (home-subpath "/Library/Caches/deno"))

;; ---------------------------------------------------------------------------
;; 30-toolchains/ruby  ·  Ruby via /opt/homebrew/opt/ruby
;; Custom: homebrew ruby binary/stdlib covered by (subpath "/opt"); only
;; per-user gem cache and bundle config need explicit grants.
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.gem")
    (home-subpath "/.config/gem")
    (home-subpath "/.cache/gem")
    (home-subpath "/.bundle")
    (home-subpath "/.config/bundle")
    (home-subpath "/Library/Caches/gem")
    (home-subpath "/Library/Caches/bundler"))

;; ---------------------------------------------------------------------------
;; 30-toolchains/java  ·  Java 17 via /opt/homebrew/opt/openjdk@17
;; Custom: JVM binary covered by (subpath "/opt"); Maven + Gradle local caches.
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.m2")
    (home-subpath "/.gradle")
    (home-subpath "/.config/gradle")
    (home-subpath "/.cache/gradle")
    (home-subpath "/Library/Caches/gradle"))

;; ---------------------------------------------------------------------------
;; 30-toolchains/python-uv  ·  Python (homebrew) + uv/uvx in ~/.local/bin
;; Custom: no safehouse uv profile; path conventions follow uv documentation.
;; Used primarily in ~/grafana/irm.
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.cache/uv")
    (home-subpath "/.local/share/uv")
    (home-subpath "/.local/state/uv")
    (home-subpath "/Library/Caches/uv")
    (home-subpath "/.config/uv"))

;; ---------------------------------------------------------------------------
;; 40-shared/agent-common  ·  Shared skill and agent guidance files
;; Source influence: 40-shared/agent-common.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.skills")
    (home-subpath "/.agents")
    (home-literal "/AGENTS.md"))

(allow file-read*
    (home-subpath "/.claude/agents")
    (home-subpath "/.claude/skills")
    (home-literal "/CLAUDE.md"))

;; ---------------------------------------------------------------------------
;; 50-integrations-core/git  ·  Git config + global ignore
;; Source influence: 50-integrations-core/git.sb
;; No private keys in ~/.ssh/; SSH auth is via 1Password agent (see §55 below).
;; ---------------------------------------------------------------------------

(allow file-read*
    (home-prefix "/.gitconfig")
    (home-prefix "/.gitignore")
    (home-subpath "/.config/git")
    (home-literal "/.gitattributes")
    (home-literal "/.ssh")
    (home-literal "/.ssh/config")
    (home-literal "/.ssh/known_hosts"))

;; ---------------------------------------------------------------------------
;; 50-integrations-core/scm-clis  ·  GitHub CLI (gh)
;; Source influence: 50-integrations-core/scm-clis.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.config/gh")
    (home-subpath "/.cache/gh")
    (home-subpath "/.local/share/gh")
    (home-subpath "/.local/state/gh"))

;; ---------------------------------------------------------------------------
;; 50-integrations-core/jj  ·  Jujutsu VCS config and state
;; Custom: binary at /opt/homebrew/bin/jj (covered by /opt); config in XDG dirs.
;; Repo-local .jj/ dirs are covered by the RW project grants below.
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.config/jj")
    (home-subpath "/.local/share/jj")
    (home-subpath "/.cache/jj"))

;; ---------------------------------------------------------------------------
;; 55-integrations-optional/keychain  ·  macOS Keychain for agent auth
;; Source influence: 55-integrations-optional/keychain.sb
;; Required by claude-code and codex for API key storage/retrieval.
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/Library/Keychains")
    (home-literal "/Library/Preferences/com.apple.security.plist"))

(allow file-read*
    (literal "/Library/Preferences/com.apple.security.plist")
    (literal "/Library/Keychains/System.keychain")
    (subpath "/private/var/db/mds"))

(allow file-read-metadata
    (home-literal "/Library/Keychains")
    (literal "/Library")
    (literal "/Library/Keychains"))

(allow mach-lookup
    (global-name "com.apple.SecurityServer")
    (global-name "com.apple.security.agent")
    (global-name "com.apple.securityd.xpc")
    (global-name "com.apple.security.authhost")
    (global-name "com.apple.secd")
    (global-name "com.apple.trustd"))

(allow ipc-posix-shm-read-data ipc-posix-shm-write-create ipc-posix-shm-write-data
    (ipc-posix-name "com.apple.AppleDatabaseChanged"))

;; ---------------------------------------------------------------------------
;; 55-integrations-optional/shell-init  ·  zsh (only; no bash/fish needed)
;; Source influence: 55-integrations-optional/shell-init.sb (zsh subset)
;; ---------------------------------------------------------------------------

(allow file-read*
    (literal "/private/etc/profile")
    (literal "/private/etc/paths")
    (subpath "/private/etc/paths.d")
    (literal "/private/etc/zprofile")
    (literal "/private/etc/zshrc")
    (home-literal "/.zshenv")
    (home-literal "/.zprofile")
    (home-literal "/.zshrc")
    (home-prefix "/.zcompdump"))

;; ---------------------------------------------------------------------------
;; 55-integrations-optional/1password  ·  SSH agent socket
;; Source influence: 55-integrations-optional/1password.sb
;; SSH private keys live in 1Password. The op-agent Unix socket lets git and
;; other tools authenticate without exposing key material on disk.
;; network* (§20) already covers the connect(2) call to the socket.
;; ---------------------------------------------------------------------------

(allow file-read-metadata
    (home-literal "/Library/Group Containers")
    (home-subpath "/Library/Group Containers/2BUA8C4S2C.com.1password"))

(allow file-read* file-write*
    (home-literal "/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"))

;; ---------------------------------------------------------------------------
;; 60-agents/claude-code  ·  Claude Code CLI + .claude state + MCP config
;; Source influence: 60-agents/claude-code.sb
;; ~/.claude/* symlinks resolve into ~/dotfiles (granted RW below).
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-prefix "/.local/bin/claude")
    (home-subpath "/.cache/claude")
    (home-subpath "/.claude")
    (home-prefix "/.claude.json")
    (home-literal "/.claude.lock")
    (home-subpath "/.config/claude")
    (home-subpath "/.local/state/claude")
    (home-subpath "/.local/share/claude")
    (home-literal "/.mcp.json"))

(allow file-read*
    (home-prefix "/.claude.json.")
    (home-literal "/Library/Application Support/Claude/claude_desktop_config.json")
    (subpath "/Library/Application Support/ClaudeCode/.claude")
    (literal "/Library/Application Support/ClaudeCode/managed-settings.json")
    (literal "/Library/Application Support/ClaudeCode/managed-mcp.json")
    (literal "/Library/Application Support/ClaudeCode/CLAUDE.md"))

;; ---------------------------------------------------------------------------
;; 60-agents/cursor-agent  ·  Cursor terminal agent
;; Custom: cursor binary is a plain file (not a symlink) at ~/.local/bin/cursor.
;; cursor-agent versions dir mirrors the layout of ~/.local/share/claude.
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-prefix "/.local/bin/cursor")
    (home-prefix "/.local/bin/agent")               ;; 'agent' alias → cursor-agent binary
    (home-subpath "/.local/share/cursor-agent")
    (home-subpath "/.config/cursor-agent")
    (home-subpath "/.cache/cursor-agent")
    (home-subpath "/.local/state/cursor-agent"))

;; ---------------------------------------------------------------------------
;; 60-agents/codex  ·  OpenAI Codex CLI
;; Source influence: 60-agents/codex.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-prefix "/.local/bin/codex")
    (home-subpath "/.codex")
    (home-subpath "/.cache/codex"))

;; ---------------------------------------------------------------------------
;; 60-agents/pi  ·  pi-coding-agent (@mariozechner/pi-coding-agent)
;; Binary is an nvm-managed Node package (covered by ~/.config/nvm RW above).
;; Runtime state (sessions, settings, lock files) lives under ~/.pi/.
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.pi"))

;; ---------------------------------------------------------------------------
;; Approved local tools  ·  Explicit read grants for permitted ~/.local/bin tools
;; gcom/gcom-dev/gcom-ops are excluded via early deny at the top.
;; mickflaggr-cli and graft-server: user-approved for agent invocation.
;; tmux-sessioniser, whatdoin: dotfiles utilities, symlinked into ~/dotfiles.
;; ---------------------------------------------------------------------------

(allow file-read*
    (home-literal "/.local/bin/mickflaggr-cli")
    (home-literal "/.local/bin/graft-server")
    (home-literal "/.local/bin/tmux-sessioniser")
    (home-literal "/.local/bin/whatdoin"))

;; ---------------------------------------------------------------------------
;; Project RW: ~/dotfiles
;; Ancestor literals follow emit_path_ancestor_literals() from render.sh.
;; Contains neovim/tmux configs, agent skills, and stow-managed dotfile trees.
;; ---------------------------------------------------------------------------

(allow file-read-metadata
    (literal "/Users")
    (literal "/Users/mthorning")
    (literal "/Users/mthorning/dotfiles"))

(allow file-read* file-write*
    (subpath "/Users/mthorning/dotfiles"))

;; ---------------------------------------------------------------------------
;; Project RW: ~/grafana
;; Ancestor literal for ~/grafana (parent /Users/mthorning already emitted above).
;; gcom scripts are denied by the early deny rule near the top of this file.
;; ---------------------------------------------------------------------------

(allow file-read-metadata
    (literal "/Users/mthorning/grafana"))

(allow file-read* file-write*
    (subpath "/Users/mthorning/grafana"))

;; gcom cloud-deployment scripts: deny read/write/exec.
;; SBPL is last-match-wins, so this must come AFTER the ~/grafana allow above.
(deny file-read* file-write* process-exec
    (subpath "/Users/mthorning/grafana/deployment_tools/scripts/gcom"))

;; ---------------------------------------------------------------------------
;; Runtime workdir grant — appended by safe-agent.sh at launch time
;; The wrapper script resolves `pwd -P`, emits ancestor file-read-metadata
;; literals, then appends an (allow file-read* file-write* (subpath WORKDIR))
;; rule. Rules here are additive: if the workdir is already inside ~/grafana or
;; ~/dotfiles the extra rules are redundant but harmless.
;; ---------------------------------------------------------------------------
